HIFIS_DB_USER=
HIFIS_DB_PASSWORD=
HIFIS_DB_NAME=
HIFIS_DB_HOST=
HIFIS_DB_PORT=

JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=

SOLAPI_API_KEY=
SOLAPI_API_SECRET=
# 정상 발송은 branch.phone 사용. 아래는 폴백·시스템 메시지용 (Solapi에 등록된 번호)
SOLAPI_SENDER=

# 알림톡 발송 활성화 (운영 전엔 false로 차단, cutover 시 true)
MESSAGING_ENABLED=true

CLAUDE_API_KEY=

CORS_ALLOWED_ORIGINS=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=
APP_BASE_URL=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=

# Sentry 에러 추적 (선택) - 비어있으면 비활성. 운영에서만 sentry.io DSN 박기
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0

# 브로제이(BroJ) 자동 회원 등록 - 회원가입 후 브로제이에도 INSERT 시도
# Branch.broj_enabled=True인 지점만 동작. JGROUP_TOKEN 만료 시 사장님이 갱신해서 .env 업데이트
BROJ_LOGIN_ID=
BROJ_LOGIN_PW=
BROJ_JGROUP_TOKEN=

# 다짐(Dagym) 자동 회원 등록 - GraphQL 기반. Branch.dajim_enabled=True인 지점만 동작
# PW는 평문 (코드가 SHA-256 hex로 변환). GYM_ID는 다짐 어드민 네트워크탭의 x-gym-id 값
DAJIM_LOGIN_EMAIL=
DAJIM_LOGIN_PW=
DAJIM_GYM_ID=